package src.JOCDELPINGU.Modelo;

//Representa un objeto utilizable dentro del juego
public class item {

    //Tipos posibles de objetos del juego
    public enum TipoItem {
        PEZ, BOLA_NIEVE, DADO
    }

    //Tipo del objeto
    private TipoItem tipo;

    //Nombre descriptivo del objeto
    private String nombre;
    
    //Inicializa el objeto segun su tipo
    public item(TipoItem tipo) {
        this.tipo = tipo;
        switch(tipo) {
            case PEZ: this.nombre = "Pez"; break;
            case BOLA_NIEVE: this.nombre = "Bola de nieve"; break;
            case DADO: this.nombre = "Dado extra"; break;
        }
    }

    //Devuelve un simbolo visual representativo del objeto
    public String getSimbolo() {
        switch(tipo) {
            case PEZ: return "🐟";
            case BOLA_NIEVE: return "❄️";
            case DADO: return "⚡";
            default: return "📦";
        }
    }

    public TipoItem getTipo() { return tipo; }
    public String getNombre() { return nombre; }
}